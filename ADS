#Task 1: Two Sum 
def two_sum(nums, target):
    d = {}
    for i, n in enumerate(nums):
        if target - n in d:
            return [d[target - n], i]
        d[n] = i


# 2: First Unique Character
def first_unique_char(s):
    count = {}
    for ch in s:
        count[ch] = count.get(ch, 0) + 1

    for i, ch in enumerate(s):
        if count[ch] == 1:
            return i
    return -1


# Task 3: Isomorphic Strings
def is_isomorphic(s, t):
    map_st, map_ts = {}, {}

    for a, b in zip(s, t):
        if (a in map_st and map_st[a] != b) or (b in map_ts and map_ts[b] != a):
            return False
        map_st[a] = b
        map_ts[b] = a
    return True


#Task 4: Happy Number
def is_happy(n):
    seen = set()

    while n != 1:
        if n in seen:
            return False
        seen.add(n)

        n = sum(int(d)**2 for d in str(n))
    return True


